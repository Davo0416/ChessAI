        </Grid>
        <Grid x:Name="AuthView"
              Visibility="Visible">

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Width="400">

                <TextBlock Text="ChessAI Login"
                           FontSize="32"
                           FontWeight="Bold"
                           Margin="0,0,0,20"
                           Foreground="White"
                           HorizontalAlignment="Center"/>

                <!-- Username -->
                <TextBox x:Name="UsernameBox"
                         Height="40"
                         Margin="0,8"
                         FontSize="16"/>

                <!-- Password -->
                <PasswordBox x:Name="PasswordBox"
                             Height="40"
                             Margin="0,8"
                             FontSize="16"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,16">

                    <Button Content="Login"
                            Width="150"
                            Height="50"
                            Margin="5"
                            Style="{StaticResource RoundedCardButton}"
                            Click="Login_Click"/>

                    <Button Content="Signup"
                            Width="150"
                            Height="50"
                            Margin="5"
                            Style="{StaticResource RoundedCardButton}"
                            Click="Signup_Click"/>
                </StackPanel>

                <TextBlock x:Name="AuthStatus"
                           Foreground="Red"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>